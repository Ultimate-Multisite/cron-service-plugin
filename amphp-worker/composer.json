{
    "name": "ultimatemultisite/cron-worker",
    "description": "AMPHP-based cron worker for Ultimate Multisite External Cron Service",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "amphp/amp": "^3.0",
        "amphp/http-client": "^5.0",
        "amphp/log": "^2.0",
        "amphp/file": "^3.0",
        "monolog/monolog": "^3.0",
        "revolt/event-loop": "^1.0"
    },
    "require-dev": {
        "amphp/phpunit-util": "^3.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "CronService\\Worker\\": "src/"
        }
    },
    "bin": ["bin/worker"],
    "scripts": {
        "start": "php bin/worker",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
